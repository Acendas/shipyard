[
  {
    "name": "has_browse_capability",
    "type": "contains",
    "pattern": "[Bb]rowse|[Ss]earch|[Ll]ook.?up"
  },
  {
    "name": "has_status_management",
    "type": "contains",
    "pattern": "status|[Aa]rchive"
  },
  {
    "name": "has_frontmatter_name",
    "type": "frontmatter_field",
    "field": "name",
    "value": "ship-spec"
  },
  {
    "name": "has_drill_down_levels",
    "type": "contains",
    "pattern": "Level 1|Level 2|Level 3|[Oo]verview.*[Ee]pic.*[Ff]eature"
  },
  {
    "name": "has_sync_subcommand",
    "type": "contains",
    "pattern": "sync|synced_at"
  },
  {
    "name": "has_absorb_feature",
    "type": "contains",
    "pattern": "absorb"
  },
  {
    "name": "has_diff_subcommand",
    "type": "contains",
    "pattern": "diff|git log"
  },
  {
    "name": "approval_uses_ask_user",
    "type": "contains",
    "pattern": "AskUserQuestion"
  },
  {
    "name": "has_state_machine",
    "type": "contains",
    "pattern": "proposed.*approved|state machine|valid transition"
  },
  {
    "name": "has_ideas_subcommand",
    "type": "contains",
    "pattern": "ideas|pending.*discussion"
  },
  {
    "name": "has_dry_run",
    "type": "contains",
    "pattern": "dry.run"
  },
  {
    "name": "uses_ask_user_question",
    "type": "contains",
    "pattern": "AskUserQuestion"
  },
  {
    "name": "uses_shipyard_data_path",
    "type": "contains",
    "pattern": "shipyard-data|shipyard-context"
  },
  {
    "name": "read_only_default",
    "type": "contains",
    "pattern": "[Rr]ead.only|read-only"
  },
  {
    "name": "no_shell_sd_substitution",
    "type": "not_contains",
    "pattern": "\\$\\(shipyard-data"
  },
  {
    "name": "no_shell_sc_substitution",
    "type": "not_contains",
    "pattern": "\\$\\(shipyard-context"
  },
  {
    "name": "no_sd_shell_var_assignment",
    "type": "not_contains",
    "pattern": "SD=\\$\\(shipyard-data"
  },
  {
    "name": "prohibits_bash_redirect_for_state",
    "type": "contains",
    "pattern": "echo.*redirect.*Write tool|Never use.*echo.*Write tool"
  }
]
