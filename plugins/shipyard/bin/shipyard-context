#!/usr/bin/env python3
"""Provide skill context without command substitution in the invocation.

Claude Code blocks $(command) in skill !` backtick commands as a security
restriction. This script wraps all data reads so skills can write:
  !`shipyard-context head config.md 50 NO_CONFIG`
instead of:
  !`head -50 $(shipyard-data)/config.md 2>/dev/null || echo "NO_CONFIG"`

Usage:
  shipyard-context path                              → SHIPYARD_DATA=/full/path
  shipyard-context head <relpath> [lines] [fallback] → head of data file
  shipyard-context cat <relpath> [fallback]          → full data file
  shipyard-context ls <reldir> [limit] [fallback]    → list directory
  shipyard-context ls-glob <pattern> [limit] [fallback] → list glob match
  shipyard-context ls-sort <pattern> [fallback]      → sorted glob match
  shipyard-context count <reldir>                    → file count
  shipyard-context spec-counts                       → epics/features/tasks/bugs/ideas/refs
  shipyard-context status-counts                     → features/epics/bugs/ideas
  shipyard-context debug-count                       → active debug sessions
"""

import glob as globmod
import os
import subprocess
import sys


def get_data_dir():
    """Resolve the Shipyard data directory via shipyard-data script."""
    script_dir = os.path.dirname(os.path.abspath(__file__))
    data_script = os.path.join(script_dir, 'shipyard-data')
    try:
        result = subprocess.run(
            [sys.executable, data_script],
            capture_output=True, text=True
        )
        if result.returncode == 0:
            return result.stdout.strip()
    except FileNotFoundError:
        pass
    return ''


def read_head(filepath, lines):
    """Read the first N lines of a file."""
    try:
        with open(filepath) as f:
            return ''.join(f.readline() for _ in range(lines))
    except (FileNotFoundError, PermissionError, OSError):
        return None


def read_cat(filepath):
    """Read entire file contents."""
    try:
        with open(filepath) as f:
            return f.read()
    except (FileNotFoundError, PermissionError, OSError):
        return None


def list_dir(dirpath, limit=20):
    """List directory entries up to limit."""
    try:
        entries = os.listdir(dirpath)
        return entries[:limit]
    except (FileNotFoundError, PermissionError, OSError):
        return None


def count_dir(dirpath):
    """Count entries in a directory."""
    try:
        return len(os.listdir(dirpath))
    except (FileNotFoundError, PermissionError, OSError):
        return 0


def list_glob(pattern, limit=20):
    """List files matching a glob pattern."""
    try:
        matches = globmod.glob(pattern)
        return [os.path.basename(m) for m in matches[:limit]]
    except (OSError,):
        return None


def list_glob_sorted(pattern):
    """List files matching a glob pattern, sorted."""
    try:
        matches = sorted(globmod.glob(pattern))
        return [os.path.basename(m) for m in matches]
    except (OSError,):
        return None


def main():
    sd = get_data_dir()
    if not sd:
        print('ERROR: Could not resolve Shipyard data directory', file=sys.stderr)
        sys.exit(1)

    cmd = sys.argv[1] if len(sys.argv) > 1 else 'help'

    if cmd == 'path':
        print(f'SHIPYARD_DATA={sd}')

    elif cmd == 'head':
        relpath = sys.argv[2] if len(sys.argv) > 2 else ''
        lines = int(sys.argv[3]) if len(sys.argv) > 3 else 50
        fallback = sys.argv[4] if len(sys.argv) > 4 else 'NO_DATA'
        if not relpath:
            print('missing relative path', file=sys.stderr)
            sys.exit(1)
        result = read_head(os.path.join(sd, relpath), lines)
        print(result if result is not None else fallback)

    elif cmd == 'cat':
        relpath = sys.argv[2] if len(sys.argv) > 2 else ''
        fallback = sys.argv[3] if len(sys.argv) > 3 else 'NO_DATA'
        if not relpath:
            print('missing relative path', file=sys.stderr)
            sys.exit(1)
        result = read_cat(os.path.join(sd, relpath))
        print(result if result is not None else fallback)

    elif cmd == 'ls':
        reldir = sys.argv[2] if len(sys.argv) > 2 else ''
        limit = int(sys.argv[3]) if len(sys.argv) > 3 else 20
        fallback = sys.argv[4] if len(sys.argv) > 4 else 'empty'
        if not reldir:
            print('missing relative dir', file=sys.stderr)
            sys.exit(1)
        entries = list_dir(os.path.join(sd, reldir), limit)
        print('\n'.join(entries) if entries else fallback)

    elif cmd == 'ls-glob':
        pattern = sys.argv[2] if len(sys.argv) > 2 else ''
        limit = int(sys.argv[3]) if len(sys.argv) > 3 else 20
        fallback = sys.argv[4] if len(sys.argv) > 4 else 'empty'
        if not pattern:
            print('missing glob pattern', file=sys.stderr)
            sys.exit(1)
        entries = list_glob(os.path.join(sd, pattern), limit)
        print('\n'.join(entries) if entries else fallback)

    elif cmd == 'ls-sort':
        pattern = sys.argv[2] if len(sys.argv) > 2 else ''
        fallback = sys.argv[3] if len(sys.argv) > 3 else 'empty'
        if not pattern:
            print('missing glob pattern', file=sys.stderr)
            sys.exit(1)
        entries = list_glob_sorted(os.path.join(sd, pattern))
        print('\n'.join(entries) if entries else fallback)

    elif cmd == 'count':
        reldir = sys.argv[2] if len(sys.argv) > 2 else ''
        if not reldir:
            print('missing relative dir', file=sys.stderr)
            sys.exit(1)
        print(count_dir(os.path.join(sd, reldir)))

    elif cmd == 'spec-counts':
        e = count_dir(os.path.join(sd, 'spec', 'epics'))
        f = count_dir(os.path.join(sd, 'spec', 'features'))
        t = count_dir(os.path.join(sd, 'spec', 'tasks'))
        b = count_dir(os.path.join(sd, 'spec', 'bugs'))
        i = count_dir(os.path.join(sd, 'spec', 'ideas'))
        r = count_dir(os.path.join(sd, 'spec', 'references'))
        print(f'Epics: {e} | Features: {f} | Tasks: {t} | Bugs: {b} | Ideas: {i} | References: {r}')

    elif cmd == 'status-counts':
        f = count_dir(os.path.join(sd, 'spec', 'features'))
        e = count_dir(os.path.join(sd, 'spec', 'epics'))
        b = count_dir(os.path.join(sd, 'spec', 'bugs'))
        i = count_dir(os.path.join(sd, 'spec', 'ideas'))
        print(f'Features: {f} | Epics: {e} | Bugs: {b} | Ideas: {i}')

    elif cmd == 'debug-count':
        debug_dir = os.path.join(sd, 'debug')
        count = 0
        try:
            for entry in os.listdir(debug_dir):
                if entry.endswith('.md') and entry != 'resolved':
                    count += 1
        except (FileNotFoundError, PermissionError, OSError):
            pass
        print(f'Debug sessions: {count} active')

    else:
        print('Usage: shipyard-context {path|head|cat|ls|ls-glob|ls-sort|count|spec-counts|status-counts|debug-count}', file=sys.stderr)
        sys.exit(1)


if __name__ == '__main__':
    main()
