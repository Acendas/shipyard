[
  {
    "name": "no_git_push",
    "type": "not_contains",
    "pattern": "\\bgit\\s+push\\b"
  },
  {
    "name": "no_sprint_branch_merge",
    "type": "not_contains",
    "pattern": "git merge.*sprint/"
  },
  {
    "name": "no_pr_merge",
    "type": "not_contains",
    "pattern": "gh pr merge"
  },
  {
    "name": "no_integration_branch",
    "type": "not_contains",
    "pattern": "integration_branch"
  },
  {
    "name": "no_git_tag_create",
    "type": "not_contains",
    "pattern": "git tag -a|git tag v"
  },
  {
    "name": "no_ship_retro_ref",
    "type": "not_contains",
    "pattern": "/ship-retro"
  },
  {
    "name": "no_ship_release_ref",
    "type": "not_contains",
    "pattern": "/ship-release"
  },
  {
    "name": "has_spec_verification",
    "type": "contains",
    "pattern": "acceptance scenario|acceptance criteria"
  },
  {
    "name": "has_test_delegation",
    "type": "contains",
    "pattern": "shipyard-test-runner"
  },
  {
    "name": "has_spec_scanner",
    "type": "contains",
    "pattern": "shipyard-review-spec"
  },
  {
    "name": "has_code_review_orchestration",
    "type": "contains",
    "pattern": "code-review-orchestration\\.md"
  },
  {
    "name": "has_code_review_stage",
    "type": "contains",
    "pattern": "Stage 0.*Code Review",
    "dotall": true
  },
  {
    "name": "has_investigator_ref",
    "type": "contains",
    "pattern": "shipyard-investigator"
  },
  {
    "name": "no_legacy_reviewer",
    "type": "not_contains",
    "pattern": "shipyard-reviewer\\b"
  },
  {
    "name": "has_visual_verification",
    "type": "contains",
    "pattern": "[Ss]creenshot|[Vv]isual"
  },
  {
    "name": "has_goal_check",
    "type": "contains",
    "pattern": "achieve the goal|feature actually works"
  },
  {
    "name": "checks_working_branch",
    "type": "contains",
    "pattern": "git branch --show-current"
  },
  {
    "name": "has_retro_section",
    "type": "contains",
    "pattern": "Sprint Retrospective"
  },
  {
    "name": "has_velocity_analysis",
    "type": "contains",
    "pattern": "[Vv]elocity"
  },
  {
    "name": "has_anti_patterns",
    "type": "contains",
    "pattern": "anti.pattern|Anti.Pattern"
  },
  {
    "name": "has_retro_only_flag",
    "type": "contains",
    "pattern": "retro-only"
  },
  {
    "name": "has_improvement_items",
    "type": "contains",
    "pattern": "improvement|action item"
  },
  {
    "name": "has_archive_sprint",
    "type": "contains",
    "pattern": "Archive|archive sprint"
  },
  {
    "name": "uses_atomic_archive_sprint_command",
    "type": "contains",
    "pattern": "shipyard-data archive-sprint"
  },
  {
    "name": "has_changelog_file",
    "type": "contains",
    "pattern": "CHANGELOG\\.md"
  },
  {
    "name": "has_frontmatter_name",
    "type": "frontmatter_field",
    "field": "name",
    "value": "ship-review"
  },
  {
    "name": "has_demo_flag",
    "type": "contains",
    "pattern": "--demo|demo"
  },
  {
    "name": "has_hotfix_review_mode",
    "type": "contains",
    "pattern": "--hotfix"
  },
  {
    "name": "has_verdict_file",
    "type": "contains",
    "pattern": "verdict|complete.*false|complete.*true"
  },
  {
    "name": "has_gap_analysis",
    "type": "contains",
    "pattern": "[Gg]ap [Aa]nalysis|[Ss]imple.*[Cc]omplex"
  },
  {
    "name": "has_quality_gate",
    "type": "contains",
    "pattern": "Quality Gate|self-review"
  },
  {
    "name": "has_critic_challenge",
    "type": "contains",
    "pattern": "shipyard-critic|review-critique|Critic Challenge"
  },
  {
    "name": "has_final_review_pass",
    "type": "contains",
    "pattern": "Final Review Pass|blind spot|false positive"
  },
  {
    "name": "approval_uses_ask_user",
    "type": "contains",
    "pattern": "AskUserQuestion"
  },
  {
    "name": "has_retro_data_file",
    "type": "contains",
    "pattern": "RETRO-DATA\\.md"
  },
  {
    "name": "has_retro_compaction_recovery",
    "type": "contains",
    "pattern": "[Cc]ompaction [Rr]ecovery"
  },
  {
    "name": "has_throughput_tracking",
    "type": "contains",
    "pattern": "throughput|pts.*hr|pts/hr"
  },
  {
    "name": "has_release_step",
    "type": "contains",
    "pattern": "released_at|status.*released"
  },
  {
    "name": "has_feature_status_to_done",
    "type": "contains",
    "pattern": "status.*done|done.*status"
  },
  {
    "name": "uses_ask_user_question",
    "type": "contains",
    "pattern": "AskUserQuestion"
  },
  {
    "name": "uses_shipyard_data_path",
    "type": "contains",
    "pattern": "shipyard-data|shipyard-context"
  },
  {
    "name": "wraps_verification_in_logcap",
    "type": "contains",
    "pattern": "shipyard-logcap"
  },
  {
    "name": "links_live_capture_reference",
    "type": "contains",
    "pattern": "live-capture\\.md"
  },
  {
    "name": "prefers_grep_before_rerun",
    "type": "contains",
    "pattern": "grep the existing capture|grep.*before.*re-run"
  },
  {
    "name": "no_shell_sd_substitution",
    "type": "not_contains",
    "pattern": "\\$\\(shipyard-data"
  },
  {
    "name": "no_shell_sc_substitution",
    "type": "not_contains",
    "pattern": "\\$\\(shipyard-context"
  },
  {
    "name": "no_sd_shell_var_assignment",
    "type": "not_contains",
    "pattern": "SD=\\$\\(shipyard-data"
  },
  {
    "name": "operational_evidence_check_stage3",
    "type": "contains",
    "pattern": "Operational Task Evidence Check|kind: operational.*verify_output",
    "dotall": true
  },
  {
    "name": "operational_review_flags_silent_pass",
    "type": "contains",
    "pattern": "SILENT-PASS|silent-pass"
  },
  {
    "name": "operational_review_checks_capture_bytes",
    "type": "contains",
    "pattern": "byte|bytes|shipyard-logcap"
  },
  {
    "name": "silent_failures_reviewer_operational_awareness",
    "type": "contains",
    "pattern": "kind: operational|operational task",
    "target": "agent:shipyard-review-silent-failures"
  },
  {
    "name": "retro_uses_atomic_idea_allocator",
    "type": "contains",
    "pattern": "shipyard-data next-id ideas"
  },
  {
    "name": "retro_source_tag_slash_convention",
    "type": "contains",
    "pattern": "source: retro/"
  },
  {
    "name": "retro_forbids_manual_idea_numbering",
    "type": "contains",
    "pattern": "Do NOT `ls spec/ideas|Do NOT ls spec/ideas|allocator is the only safe way",
    "dotall": true
  },
  {
    "name": "stage4_captures_out_of_scope_as_ideas",
    "type": "contains",
    "pattern": "Capture Out-of-Scope Gaps as IDEAs"
  },
  {
    "name": "stage4_uses_review_gap_source_tag",
    "type": "contains",
    "pattern": "source: review-gap/"
  },
  {
    "name": "stage4_idea_cap_five_per_stage",
    "type": "contains",
    "pattern": "5 IDEAs per review stage|5 per stage",
    "dotall": true
  },
  {
    "name": "stage4_out_of_scope_only",
    "type": "contains",
    "pattern": "out-of-scope only|Out-of-scope \\(real|EXCLUSIVELY for observations",
    "dotall": true
  },
  {
    "name": "stage4_found_during_field",
    "type": "contains",
    "pattern": "found_during:.*surface-gap-stage-4|found_during:.*code-review-stage-0",
    "dotall": true
  },
  {
    "name": "stage0_out_of_scope_ideas_cross_ref",
    "type": "contains",
    "pattern": "Out-of-scope findings in Stage 0|code-review-stage-0",
    "dotall": true
  },
  {
    "name": "simplification_stage_exists",
    "type": "contains",
    "pattern": "Stage 0\\.5.*[Ss]implif"
  },
  {
    "name": "simplification_uses_code_simplifier",
    "type": "contains",
    "pattern": "code-simplifier"
  },
  {
    "name": "simplification_scope_guard",
    "type": "contains",
    "pattern": "scope guard|only touches files in the sprint diff"
  },
  {
    "name": "prohibits_bash_redirect_for_state",
    "type": "contains",
    "pattern": "echo.*redirect.*Write tool|Never use.*echo.*Write tool"
  }
]
